# Inside-container paths
INPUT_DIR="/data/input"
OUTPUT_DIR="/data/output"

# OCR languages (Tesseract will pick what fits best)
OCR_LANG="eng+rus+spa+fra+ara"

# Image resolution for PDF → image
DENSITY=300

# File extension to scan
FILE_EXT="pdf"

# Logging
LOG_LEVEL="info"

# Parallelism
MAX_PROCS=8
